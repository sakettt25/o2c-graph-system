{
  "name": "o2c-graph-dodge",
  "version": 2,
  "regions": ["iad1"],
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "functions": {
    "app/api/**": {
      "memory": 2048,
      "maxDuration": 30
    }
  },
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key"
  },
  "installCommand": "npm ci --legacy-peer-deps"
}
